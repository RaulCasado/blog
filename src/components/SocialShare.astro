---
export interface Props {
  url: string;
  title: string;
  description?: string;
  lang?: string;
}

const { url, title, description, lang = 'es' } = Astro.props;

const encodedUrl = encodeURIComponent(url);
const encodedTitle = encodeURIComponent(title);
const encodedDescription = description ? encodeURIComponent(description) : '';
const isEnglish = lang === 'en';
const shareTitle = isEnglish ? 'Share this article:' : 'Comparte este artículo:';
const shareLabel = isEnglish ? 'Share on' : 'Compartir en';
const copyLabel = isEnglish ? 'Copy link' : 'Copiar enlace';
const copiedLabel = isEnglish ? 'Link copied!' : '¡Enlace copiado!';
const copyErrorLabel = isEnglish ? 'Error copying link' : 'Error al copiar';

const platforms = [
  {
    name: 'Twitter',
    iconLabel: 'X',
    url: `https://twitter.com/intent/tweet?url=${encodedUrl}&text=${encodedTitle}`,
  },
  {
    name: 'Facebook',
    iconLabel: 'f',
    url: `https://www.facebook.com/sharer/sharer.php?u=${encodedUrl}`,
  },
{
    name: 'LinkedIn',
    iconLabel: 'in',
    url: `https://www.linkedin.com/shareArticle?mini=true&url=${encodedUrl}&title=${encodedTitle}&summary=${encodedDescription}`,
},
  {
    name: 'Reddit',
    iconLabel: 'r',
    url: `https://www.reddit.com/submit?url=${encodedUrl}&title=${encodedTitle}`,
  }
];
---

<div class="social-share-container">
  <h2 class="social-share-title">{shareTitle}</h2>
  <div class="social-share-buttons">
    {platforms.map(platform => (
      <a
        href={platform.url}
        target="_blank"
        rel="noopener noreferrer"
        class="social-share-button"
        aria-label={`${shareLabel} ${platform.name}`}
        title={`${shareLabel} ${platform.name}`}
      >
        <span class="social-share-icon social-share-text-icon" aria-hidden="true">{platform.iconLabel}</span>
        <span class="sr-only">{platform.name}</span>
      </a>
    ))}
    <button
      id="copy-link-button"
      class="social-share-button"
      aria-label={copyLabel}
      title={copyLabel}
    >
      <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor" class="social-share-icon">
        <path d="M16 1H4c-1.1 0-2 .9-2 2v14h2V3h12V1zm3 4H8c-1.1 0-2 .9-2 2v14c0 1.1.9 2 2 2h11c1.1 0 2-.9 2-2V7c0-1.1-.9-2-2-2zm0 16H8V7h11v14z"></path>
      </svg>
      <span class="sr-only">{copyLabel}</span>
    </button>
  </div>
  <div id="copy-link-feedback" class="copy-link-feedback" aria-live="polite"></div>
</div>

<script define:vars={{ urlToCopy: url, copiedLabel, copyErrorLabel }}>
  const copyButton = document.getElementById('copy-link-button');
  const feedbackElement = document.getElementById('copy-link-feedback');

  if (copyButton && feedbackElement) {
    copyButton.addEventListener('click', async () => {
      try {
        await navigator.clipboard.writeText(urlToCopy);
        feedbackElement.textContent = copiedLabel;
        feedbackElement.style.opacity = '1';
        setTimeout(() => {
          feedbackElement.style.opacity = '0';
          feedbackElement.textContent = '';
        }, 2000);
      } catch (err) {
        console.error('Error al copiar el enlace: ', err);
        feedbackElement.textContent = copyErrorLabel;
        feedbackElement.style.opacity = '1';
         setTimeout(() => {
          feedbackElement.style.opacity = '0';
          feedbackElement.textContent = '';
        }, 2000);
      }
    });
  }
</script>

<style>
  .social-share-container {
    margin-top: 2.5rem;
    margin-bottom: 1.5rem;
    padding-top: 1.5rem;
    border-top: 1px solid hsl(var(--border) / 0.5);
  }

  .social-share-title {
    font-size: 1.1rem;
    font-weight: 600;
    margin-bottom: 1rem;
    color: hsl(var(--foreground));
  }

  .social-share-buttons {
    display: flex;
    flex-wrap: wrap;
    gap: 0.75rem;
    align-items: center;
  }

  .social-share-button {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    padding: 0.6rem;
    background-color: hsl(var(--secondary) / 0.3);
    color: hsl(var(--foreground));
    border-radius: var(--radius);
    transition: background-color 0.2s ease, transform 0.2s ease;
    border: 1px solid hsl(var(--border) / 0.7);
  }

  .social-share-button:hover {
    background-color: hsl(var(--secondary) / 0.6);
    transform: translateY(-1px);
  }

  .social-share-icon {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 1.25rem;
    height: 1.25rem;
  }

  .social-share-text-icon {
    font-size: 0.85rem;
    font-weight: 700;
    line-height: 1;
  }

  .sr-only {
    position: absolute;
    width: 1px;
    height: 1px;
    padding: 0;
    margin: -1px;
    overflow: hidden;
    clip: rect(0, 0, 0, 0);
    white-space: nowrap;
    border-width: 0;
  }

  .copy-link-feedback {
    margin-top: 0.5rem;
    font-size: 0.875rem;
    color: hsl(var(--primary));
    opacity: 0;
    transition: opacity 0.3s ease-in-out;
  }
</style>
