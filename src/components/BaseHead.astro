---
import '../styles/global.css';
import { SITE_TITLE } from '../consts';

interface Props {
	title: string;
	description: string;
	image?: string;
	lang?: string;
	pageType?: 'home' | 'article' | 'about' | 'page';
	pubDate?: Date;
	updatedDate?: Date;
	tags?: string[];
}

const {
	title,
	description,
	image = '/blog-placeholder-1.jpg',
	lang = 'es',
	pageType = 'page',
	pubDate,
	updatedDate,
	tags = [],
} = Astro.props;

const canonicalURL = new URL(Astro.url.pathname, Astro.site);
const imageURL = new URL(image, Astro.url);

// Language alternates: routes are symmetric (/es/... <-> /en/...),
// so the alternate URL is the current path with its leading lang segment swapped.
const altPath = (target: string) =>
	Astro.url.pathname.replace(/^\/(es|en)(\/|$)/, `/${target}$2`);
const esURL = new URL(altPath('es'), Astro.site);
const enURL = new URL(altPath('en'), Astro.site);

const ogType = pageType === 'article' ? 'article' : 'website';
const ogLocale = lang === 'en' ? 'en_US' : 'es_ES';
const ogLocaleAlt = lang === 'en' ? 'es_ES' : 'en_US';

const AUTHOR_NAME = 'Raúl Casado Moreno';
const aboutURL = new URL(`/${lang}/about/`, Astro.site).href;
const sameAs = [
	'https://github.com/RaulCasado',
	'https://www.linkedin.com/in/raul-casado-moreno/',
];
const jobTitle = lang === 'en' ? 'Full Stack Developer' : 'Desarrollador Full Stack';

const publishedISO = pubDate ? new Date(pubDate).toISOString() : undefined;
const modifiedISO = updatedDate || pubDate ? new Date(updatedDate || pubDate!).toISOString() : undefined;

const personSchema = {
	'@context': 'https://schema.org',
	'@type': 'Person',
	name: AUTHOR_NAME,
	url: aboutURL,
	jobTitle,
	sameAs,
};

const websiteSchema = {
	'@context': 'https://schema.org',
	'@type': 'WebSite',
	name: 'Raúl Casado',
	url: Astro.site?.href,
	inLanguage: lang,
};

const articleSchema =
	pageType === 'article'
		? {
				'@context': 'https://schema.org',
				'@type': 'BlogPosting',
				headline: title,
				description,
				datePublished: publishedISO,
				dateModified: modifiedISO,
				image: imageURL.href,
				inLanguage: lang,
				keywords: tags.length ? tags.join(', ') : undefined,
				author: { '@type': 'Person', name: AUTHOR_NAME, url: aboutURL },
				publisher: { '@type': 'Person', name: AUTHOR_NAME, url: aboutURL },
				mainEntityOfPage: canonicalURL.href,
			}
		: null;

const schemas = [];
if (pageType === 'home') schemas.push(websiteSchema, personSchema);
else if (pageType === 'about') schemas.push(personSchema);
else if (articleSchema) schemas.push(articleSchema);
---

<!-- Global Metadata -->
<meta charset="utf-8" />
<meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=5.0, minimum-scale=1.0" />
<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
<link rel="sitemap" href="/sitemap-index.xml" />
<link
	rel="alternate"
	type="application/rss+xml"
	title={`${SITE_TITLE} (${lang.toUpperCase()})`}
	href={new URL(`${lang}/rss.xml`, Astro.site)}
/>
<meta name="generator" content={Astro.generator} />

<!-- Font preloads -->
<link rel="preload" href="/fonts/atkinson-regular.woff" as="font" type="font/woff" crossorigin />
<link rel="preload" href="/fonts/atkinson-bold.woff" as="font" type="font/woff" crossorigin />

<!-- Canonical & language alternates -->
<link rel="canonical" href={canonicalURL} />
<link rel="alternate" hreflang="es" href={esURL} />
<link rel="alternate" hreflang="en" href={enURL} />
<link rel="alternate" hreflang="x-default" href={esURL} />

<!-- Primary Meta Tags -->
<title>{title}</title>
<meta name="title" content={title} />
<meta name="description" content={description} />

<!-- Theme Management - Early load to prevent flash -->
<script is:inline>
  // Immediately apply the saved theme to prevent flash of unstyled content
  const getPreferredTheme = () => {
    const savedTheme = localStorage.getItem('theme');
    if (savedTheme) return savedTheme;
    return window.matchMedia('(prefers-color-scheme: dark)').matches ? 'dark' : 'light';
  };

  // Apply theme right away before page loads
  document.documentElement.classList.add(getPreferredTheme());
</script>

<!-- Open Graph / Facebook -->
<meta property="og:type" content={ogType} />
<meta property="og:url" content={Astro.url} />
<meta property="og:title" content={title} />
<meta property="og:description" content={description} />
<meta property="og:image" content={imageURL} />
<meta property="og:locale" content={ogLocale} />
<meta property="og:locale:alternate" content={ogLocaleAlt} />

{pageType === 'article' && (
	<>
		{publishedISO && <meta property="article:published_time" content={publishedISO} />}
		{modifiedISO && <meta property="article:modified_time" content={modifiedISO} />}
		<meta property="article:author" content={AUTHOR_NAME} />
		{tags.map(tag => <meta property="article:tag" content={tag} />)}
	</>
)}

<!-- Twitter -->
<meta name="twitter:card" content="summary_large_image" />
<meta name="twitter:url" content={Astro.url} />
<meta name="twitter:title" content={title} />
<meta name="twitter:description" content={description} />
<meta name="twitter:image" content={imageURL} />

<!-- Structured data -->
{schemas.map(schema => (
	<script type="application/ld+json" is:inline set:html={JSON.stringify(schema)} />
))}
