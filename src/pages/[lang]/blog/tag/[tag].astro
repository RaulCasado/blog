---
import { getCollection } from 'astro:content';
import StandardPageLayout from '../../../../layouts/StandardPageLayout.astro';
import { Picture } from 'astro:assets';
import { useTranslations } from '../../../../i18n/utils';
import { languages } from '../../../../i18n/ui';
import fallbackHeroImage from '../../../../assets/blog/blog-placeholder-1.jpg';

export async function getStaticPaths() {
  const allPosts = await getCollection('blog');
  const paths = [];

  for (const lang of Object.keys(languages)) {
    const langPosts = allPosts.filter(post => post.id.startsWith(`${lang}/`));
    const tags = [...new Set(langPosts.flatMap(post => post.data.tags || []))];
    for (const tag of tags) {
      paths.push({ params: { lang, tag }, props: { tag } });
    }
  }

  return paths;
}

const { lang } = Astro.params;
const { tag } = Astro.props;
const t = useTranslations(lang);

const allPosts = await getCollection('blog', ({ id, data }) => {
  return id.startsWith(`${lang}/`) && (data.tags || []).includes(tag);
});

const sortedPosts = allPosts.sort(
  (a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf()
);

const getPostUrl = (id: string) => `/${lang}/blog/${id.replace(new RegExp(`^${lang}/`), '').replace(/\.mdx?$/, '')}/`;
const dateLocale = lang === 'es' ? 'es-ES' : 'en-US';
const cardImageWidths = [360, 540, 720, 960];
const cardImageSizes = '(min-width: 1024px) 33vw, (min-width: 768px) 50vw, 100vw';
---
<StandardPageLayout title={`${t('blog.taggedWith')} "${tag}"`} description={`${t('blog.taggedWith')} "${tag}"`} lang={lang}>
  <div class="blog-container">
    <h1>{t('blog.taggedWith')} "#{tag}"</h1>

    <a href={`/${lang}/blog`} class="back-link">{t('blog.backToPosts')}</a>

    <div class="posts-grid">
      {sortedPosts.map(post => (
        <article class="post-card">
          <a href={getPostUrl(post.id)} class="post-image-link">
            <Picture
              src={post.data.heroImage || fallbackHeroImage}
              alt={post.data.heroImageAlt || post.data.title}
              class="post-image"
              formats={['avif', 'webp']}
              fallbackFormat="jpg"
              widths={cardImageWidths}
              sizes={cardImageSizes}
              width={720}
              height={360}
              quality={80}
              loading="lazy"
            />
          </a>
          <div class="post-card-content">
            <h2>
              <a href={getPostUrl(post.id)}>{post.data.title}</a>
            </h2>
            <p>{post.data.description}</p>
            <div class="post-meta">
              <time>{post.data.pubDate.toLocaleDateString(dateLocale)}</time>
            </div>
          </div>
        </article>
      ))}
    </div>
  </div>
</StandardPageLayout>

<style>
.posts-grid {
  display: grid;
  grid-template-columns: repeat(auto-fit, minmax(320px, 1fr));
  gap: 2rem;
  margin-top: 2rem;
}

.post-card {
  background: hsl(var(--background));
  border-radius: 1.2rem;
  box-shadow: 0 2px 16px 0 rgba(0,0,0,0.08);
  overflow: hidden;
  display: flex;
  flex-direction: column;
  transition: box-shadow 0.2s;
}

.post-card:hover {
  box-shadow: 0 4px 32px 0 rgba(0,0,0,0.13);
}

.post-image-link {
  display: block;
  overflow: hidden;
}

.post-image {
  width: 100%;
  aspect-ratio: 16/9;
  object-fit: cover;
  transition: transform 0.3s;
  border-bottom: 1px solid hsl(var(--border));
}

.post-card:hover .post-image {
  transform: scale(1.04);
}

.post-card-content {
  padding: 1.2rem 1.5rem 1.5rem 1.5rem;
  display: flex;
  flex-direction: column;
  flex: 1;
}

.post-card-content h2 {
  font-size: 1.25rem;
  margin: 0 0 0.5rem 0;
  line-height: 1.2;
}

.post-card-content p {
  color: hsl(var(--muted-foreground));
  margin-bottom: 1rem;
  flex: 1;
}

.post-meta {
  font-size: 0.95rem;
  color: hsl(var(--muted-foreground));
  margin-top: auto;
  display: flex;
  gap: 1rem;
  align-items: center;
}

.back-link {
  display: inline-block;
  margin-bottom: 1.5rem;
  color: hsl(var(--primary));
  text-decoration: none;
  font-weight: 500;
  transition: color 0.2s;
}

.back-link:hover {
  color: hsl(var(--primary-foreground));
}
</style>
