---
import BaseHead from '../../../components/BaseHead.astro';
import Header from '../../../components/Header.astro';
import Footer from '../../../components/Footer.astro';
import { getCollection } from 'astro:content';
import BlogIndexContent from '../../../components/pages/BlogIndexContent.astro';
import { useTranslations } from '../../../i18n/utils';
import { languages } from '../../../i18n/ui';
import { getLangPosts, PAGE_SIZE } from '../../../utils/posts';

export function getStaticPaths() {
	return Object.keys(languages).map((lang) => ({ params: { lang } }));
}

const { lang } = Astro.params;
const t = useTranslations(lang);

const posts = getLangPosts(await getCollection('blog'), lang);
const totalPages = Math.max(1, Math.ceil(posts.length / PAGE_SIZE));
const pagePosts = posts.slice(0, PAGE_SIZE);
const allTags = [...new Set(posts.flatMap(post => post.data.tags || []))];
---

<!doctype html>
<html lang={lang}>
	<head>
		<BaseHead title={t('blog.metaTitle')} description={t('blog.metaDescription')} lang={lang} />
		<meta name="viewport" content="width=device-width, initial-scale=1.0">
	</head>
	<body>
		<Header />
		<main>
			<BlogIndexContent
				lang={lang}
				posts={pagePosts}
				allTags={allTags}
				t={t}
				currentPage={1}
				totalPages={totalPages}
			/>
		</main>
		<Footer />
	</body>
</html>
