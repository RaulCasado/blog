---
import BaseHead from '../../../components/BaseHead.astro';
import Header from '../../../components/Header.astro';
import Footer from '../../../components/Footer.astro';
import { getCollection } from 'astro:content';
import BlogIndexContent from '../../../components/pages/BlogIndexContent.astro';
import { useTranslations } from '../../../i18n/utils';

const lang = 'es';
const t = useTranslations(lang);

const allPosts = await getCollection('blog');
const posts = allPosts
  .filter(post => post.id.startsWith('es/'))
  .sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf());

const allTags = [...new Set(posts.flatMap(post => post.data.tags || []))];

---

<!doctype html>
<html lang="es">
	<head>
		<BaseHead title={t('blog.metaTitle')} description={t('blog.metaDescription')} lang={lang} />
		<meta name="viewport" content="width=device-width, initial-scale=1.0">
	</head>
	<body>
		<Header />
		<main>
			<BlogIndexContent lang={lang} posts={posts} allTags={allTags} t={t} />
		</main>
		<Footer />
	</body>
</html>